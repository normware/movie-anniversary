# TMDB API Read Access Token (v4) – get one at https://www.themoviedb.org/settings/api
TMDB_TOKEN=your_tmdb_api_read_access_token_here

# Key used to encrypt/decrypt the cached movie data (src/movies.enc.json)
# Must be at least 32 characters long
DATA_ENCRYPTION_KEY=your_32_character_encryption_key_here
